The following document provides a detailed description of the R code used and the analysis conducted to evaluate the container and entomological data of *Aedes aegypti* collected through 2022-2023 during the rainy and dry seasons of both years in District 3 of Managua, Nicaragua.

```{r, loading libraries}
library(DHARMa)
library(MASS)
library(effects)
library(ggplot2)
library(ggtext)
library(tidyverse)
library(dplyr)
library(gamm4)
library(glmmTMB)
library(mgcv)
library(gapminder)
library(patchwork)
library(performance) #provides measures to assess model quality like R-squared
library(see) #needed to plot collinearity of variables in the model
library(emmeans) #used for post hoc comparisons "contrasts"
library(ggeffects)

df <- read.csv("~/Library/CloudStorage/OneDrive-Personal/GitHub/UrbanoRural/Aedes_aegypti_household_dataset.csv")

```

## Data cleaning

Here is the procedure of data cleaning and how the temperature and humidity variables were generated.

```{r}
df <- read.csv("~/Library/CloudStorage/OneDrive-Personal/GitHub/UrbanoRural/Supplementary_household_dataset.csv")

df <- df %>%
  mutate(
    PeriHora = ifelse(PeriHora %in% c("0:00", "00:00"), NA, PeriHora),
    IntraHora = ifelse(IntraHora %in% c("0:00", "00:00"), NA, IntraHora),
    PeriHora_decimal = hour(hm(PeriHora)) +
      minute(hm(PeriHora)) / 60,
    IntraHora_decimal = hour(hm(IntraHora)) +
      minute(hm(IntraHora)) / 60
  )

df <- df %>%
  dplyr::mutate(
    PeriHora  = ifelse(PeriHora %in% c("0:00","00:00"), NA, PeriHora),
    IntraHora = ifelse(IntraHora %in% c("0:00","00:00"), NA, IntraHora),
    Hour = dplyr::coalesce(PeriHora, IntraHora),
    Hour_decimal = hour(hm(Hour)) + minute(hm(Hour)) / 60
  )


```

# Pupal container productivity

The following code show how to generate Figure 2 shown in the main text of the manuscript detailing the percentage and productivity of pupae with containers. The GLMM comparison of pupal abundance and barrel management.

```{r, Containers}

df1 <- df %>%
    dplyr::select(
    Year, Season, Community, 
    TotBarAgua, TotBarPosPupa, NumPupaBar,
    TotPilaAgua, TotPilaPosPupa, NumPupaPila,
    TotLlanAgua, TotLlanPosPupa, NumPupaLlan,
    TotBaldeAgua, TotBaldePosPupa, NumPupaBalde,
    TotOtroAgua, TotOtroPosPupa, NumPupaOtro
  ) %>%
  pivot_longer(
    cols = -c(Year, Season, Community),
    names_to = "var",
    values_to = "value"
  ) %>%
  mutate(
    Container_Type = case_when(
      str_detect(var, "Bar")   ~ "Barrels",
      str_detect(var, "Pila")  ~ "ConcreteWB",
      str_detect(var, "Llan")  ~ "Tires",
      str_detect(var, "Balde") ~ "Buckets",
      str_detect(var, "Otro")  ~ "Other",
      TRUE ~ NA_character_
    ),
    Metric = case_when(
      str_detect(var, "Agua$")    ~ "Total",
      str_detect(var, "PosPupa$") ~ "Positive",
      str_detect(var, "^NumPupa") ~ "Pupae",
      TRUE ~ NA_character_
    )
  ) %>%
  filter(!is.na(Container_Type), !is.na(Metric)) %>%
  group_by(Year, Season, Community, Container_Type, Metric) %>%
  summarise(value = sum(value, na.rm = TRUE), .groups = "drop") %>%
  pivot_wider(
    names_from = Metric,
    values_from = value
  ) %>%
  arrange(Year, Season, Community, Container_Type)

df1 <- df1 %>%
  group_by(Year, Season, Community) %>%
  mutate(
    Percent_Total_Containers = 100 * Total / sum(Total, na.rm = TRUE),
