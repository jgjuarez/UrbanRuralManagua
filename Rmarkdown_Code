valid_value <- function(x) {
  # Coerce safely to character
  x <- trimws(as.character(x))
  
  # Empty strings → NA
  x[x == ""] <- NA
  
  # Convert to numeric (suppress warnings from junk values)
  x_num <- suppressWarnings(as.numeric(x))
  
  # Disregard values that start with "0." OR are <= 0
  x_num[x_num <= 0] <- NA
  
  return(x_num)
}

df3 <- df2 %>%
  dplyr::mutate(
    TempAverage = rowMeans(
